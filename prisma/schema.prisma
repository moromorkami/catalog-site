generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ImageType {
  SUPPLIER
  QC
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  PAID
  SHIPPED
  CANCELLED
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  sourceUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  productCategories ProductCategory[]

  @@unique([parentId, slug])
  @@index([parentId])
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String?
  sourceUrl   String?
  yupooUrl    String?

  supplierId  String
  brandId     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier    Supplier @relation(fields: [supplierId], references: [id])
  brand       Brand?   @relation(fields: [brandId], references: [id])

  categories  ProductCategory[]
  images      ProductImage[]
  qcSets      QcSet[]
  mappings    ProductMapping[]

  orderItems  OrderItem[]

  @@index([supplierId])
  @@index([brandId])
}

model ProductCategory {
  productId  String
  categoryId String

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model QcSet {
  id         String   @id @default(uuid())
  productId  String
  title      String?
  warehouse  String?
  notes      String?
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductImage[]
}

model ProductImage {
  id         String    @id @default(uuid())
  productId  String
  type       ImageType
  url        String
  sortOrder  Int       @default(0)

  qcSetId    String?
  qcSet      QcSet?    @relation(fields: [qcSetId], references: [id], onDelete: Cascade)

  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now())

  @@index([productId, type])
  @@index([qcSetId])
}

model ProductMapping {
  id          String   @id @default(uuid())
  productId   String
  externalUrl String   @unique
  yupooUrl    String?
  notes       String?
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id        String      @id @default(uuid())
  status    OrderStatus @default(NEW)

  name      String?
  email     String?
  phone     String?
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  qty       Int      @default(1)

  variant   String?  // size/color/etc
  note      String?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}
